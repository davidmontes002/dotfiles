{
    "label" : "lock",
    "action" : "hyprctl dispatch exit",
    "text" : "Cerrar Sesión",
    "keybind" : "e"
}
{
    "label" : "reboot",
    "action" : "systemctl reboot",
    "text" : "Reiniciar",
    "keybind" : "r"
}
{
    "label" : "shutdown",
    "action" : "systemctl poweroff",
    "text" : "Apagar",
    "keybind" : "s"
}
